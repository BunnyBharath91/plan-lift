generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  floorPlans   FloorPlan[]
  renderJobs   RenderJob[]
}

model FloorPlan {
  id          String   @id @default(uuid())
  userId      String?
  title       String
  description String?
  sourceType  String   @default("upload")
  filePath    String?
  fileUrl     String?
  widthMeters Float?
  heightMeters Float?
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
  renderJobs  RenderJob[]
}

model RenderJob {
  id           String   @id @default(uuid())
  floorPlanId  String
  userId       String?
  stylePreset  String   @default("modern_minimal")
  cameraPreset String   @default("isometric")
  status       String   @default("queued")
  errorMessage String?
  createdAt    DateTime @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  floorPlan    FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id])
  renderImages RenderImage[]
  aiCallLogs   AiCallLog[]
}

model RenderImage {
  id         String   @id @default(uuid())
  jobId      String
  imagePath  String?
  imageUrl   String?
  width      Int?
  height     Int?
  format     String?
  viewLabel  String?
  createdAt  DateTime @default(now())
  job        RenderJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model AiCallLog {
  id               String   @id @default(uuid())
  jobId            String
  provider         String   @default("openai")
  model            String
  role             String
  promptSummary    String?
  responseMetadata Json?
  createdAt        DateTime @default(now())
  job              RenderJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
